{
  "name": "mock-fh5",
  "version": "0.0.469",
  "description": "prototype - simple REST api server with Forza Horizon 5 data...",
  "author": "eswat2",
  "repository": "eswat2/mock-fh5",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "dependencies": {
    "chance": "1.1.13",
    "fs": "0.0.1-security",
    "nanoid": "5.1.11",
    "papaparse": "5.5.3",
    "path": "0.12.7",
    "vin-generator": "1.0.1"
  },
  "devDependencies": {
    "bumpp": "11.1.0",
    "chai": "6.2.2",
    "cspell": "10.0.0",
    "env-cmd": "11.0.0",
    "mocha": "11.7.6",
    "only-allow": "1.2.2",
    "prettier": "3.8.3",
    "vercel": "54.5.1",
    "yoctocolors": "2.1.2"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "vc --prod",
    "release": "pnpm bump && pnpm build && pnpm test && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "sample": "node sample.mjs",
    "dev": "env-cmd -x -- vc dev --listen 8082 --token \\$API_TOKEN",
    "cc": "prettier --check api utils tests",
    "format": "prettier --write api utils tests",
    "spell": "cspell './**/*.js'",
    "test": "mocha ./tests/*.js",
    "build": "pnpm format",
    "open": "open https://mock-fh5.vercel.app",
    "cars": "open https://mock-fh5.vercel.app/api/cars",
    "solution": "open https://mock-fh5.vercel.app/api/solution"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "printWidth": 100
  }
}
